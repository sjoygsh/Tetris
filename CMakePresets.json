{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vcpkg",
      "inherits": "default",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "vcpkg-system",
      "inherits": "default",
      "toolchainFile": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake"
    }
  ]
}